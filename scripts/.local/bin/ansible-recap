#!/usr/bin/env bash
# ansible-recap -- run ansible-playbook and fire a notify-send recap.
#
# Defaults DBUS_SESSION_BUS_ADDRESS to the canonical per-uid session bus
# socket so notify-send can reach mako/dunst even from non-interactive
# contexts (cron, keybinds, future units).
#
# Behavior:
#   full success, nothing changed  -> "Dotfiles synced [checkmark]" / "<host> up to date" (15s)
#   success, some tasks changed    -> "Dotfiles synced [checkmark]" / "<host> . N changed" + task list (15s)
#   failure                        -> "Ansible [x] N failed" / recap counts + failed task list (persistent)

set -euo pipefail

repo_root="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")/../../.." && pwd)"

if [[ $# -eq 0 ]]; then
    set -- -i "$repo_root/ansible/inventory.yml" "$repo_root/ansible/local.yml"
fi

if [[ -z "${DBUS_SESSION_BUS_ADDRESS:-}" ]]; then
    export DBUS_SESSION_BUS_ADDRESS="unix:path=/run/user/${UID}/bus"
fi

log_file="$(mktemp -t ansible-recap.XXXXXX.log)"
trap 'rm -f "$log_file"' EXIT

set +e
ansible-playbook "$@" 2>&1 | tee "$log_file"
rc=${PIPESTATUS[0]}
set -e

host="localhost"
ok=0; changed=0; unreachable=0; failed=0; skipped=0; rescued=0; ignored=0
changed_tasks=""
failed_tasks=""
current_task=""

while IFS= read -r line; do
    if [[ "$line" =~ ^TASK\ \[([^\]]+)\] ]]; then
        current_task="${BASH_REMATCH[1]}"
        continue
    fi
    if [[ "$line" =~ ^([[:alnum:]_-]+)[[:space:]]*:[[:space:]]+(ok=.+)$ ]]; then
        host="${BASH_REMATCH[1]}"
        recap_stats="${BASH_REMATCH[2]}"
        for kv in $recap_stats; do
            k="${kv%%=*}"
            v="${kv#*=}"
            case "$k" in
                ok)         ok="$v" ;;
                changed)    changed="$v" ;;
                unreachable) unreachable="$v" ;;
                failed)     failed="$v" ;;
                skipped)    skipped="$v" ;;
                rescued)    rescued="$v" ;;
                ignored)   ignored="$v" ;;
            esac
        done
        continue
    fi
    if [[ -n "$current_task" ]]; then
        if [[ "$line" =~ ^changed:\ \[ ]]; then
            changed_tasks+="$current_task"$'\n'
        elif [[ "$line" =~ ^fatal:\ \[ ]]; then
            failed_tasks+="$current_task"$'\n'
        fi
    fi
done < "$log_file"

dedupe() {
    [[ -z "$1" ]] && return
    # Strip the trailing newline appended at item-add time, then re-check:
    # an empty $1 was either never populated or had only blank task names.
    local trimmed="${1%$'\n'}"
    [[ -z "$trimmed" ]] && return
    printf '%s\n' "$trimmed" | sort -u
}

if [[ "$rc" -ne 0 || "$failed" -gt 0 || "$unreachable" -gt 0 ]]; then
    summary="Ansible ✗ ${failed} failed"
    body="${host}: ok=${ok} changed=${changed} failed=${failed} skipped=${skipped}"
    deduped="$(dedupe "$failed_tasks")"
    if [[ -n "$deduped" ]]; then
        body+=$'\n\nfailed:'$'\n'"$deduped"
    elif [[ "$rc" -ne 0 ]]; then
        body+=$'\n'"(playbook exited with code ${rc})"
    fi
    urgency=critical
    icon=dialog-error
    expire=0
else
    summary="Dotfiles synced ✓"
    if [[ "$changed" -eq 0 ]]; then
        body="${host} up to date"
    else
        body="${host} · ${changed} changed"
        deduped="$(dedupe "$changed_tasks")"
        if [[ -n "$deduped" ]]; then
            body+=$'\n\nchanged:'$'\n'"$deduped"
        fi
    fi
    urgency=low
    icon=emblem-default
    expire=15000
fi

notify-send -u "$urgency" -i "$icon" -t "$expire" -a "Ansible" "$summary" "$body" || true

exit "$rc"
