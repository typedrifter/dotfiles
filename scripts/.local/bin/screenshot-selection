#!/bin/bash
set -euo pipefail

mkdir -p ~/Pictures/screenshots
FILE="$HOME/Pictures/screenshots/$(date +'%Y-%m-%d_%H-%M-%S').png"

if grim -g "$(slurp)" - | tee "$FILE" | wl-copy; then
    notify-send \
        --app-name="Screenshot" \
        --icon="$FILE" \
        "Screenshot Saved" \
        "$(basename "$FILE")"
else
    notify-send \
        --app-name="Screenshot" \
        "Screenshot Cancelled" \
        "No area selected"
fi
