#!/usr/bin/env bash



export FZF_DEFAULT_OPTS=$FZF_DEFAULT_OPTS'

  --color=fg:#aeafb0,fg+:#d0d0d0,bg:#021727,bg+:#021727
  --color=hl:#5f87af,hl+:#577f63,info:#dbc074,marker:#87ff00
  --color=prompt:#9d79d6,spinner:#af5fff,pointer:#021727,header:#87afaf
  --color=gutter:#021727,border:#cdcecf,label:#aeaeae,query:#d9d9d9
  --margin="0" --padding="0" --prompt="open project: " --marker=" "
  --pointer=" " --separator="─" --scrollbar="│" --layout="reverse"
  --info="right"'

switch_to() {
    footclient -N tmux attach-session -t "$1"
}

has_session() {
    tmux list-sessions | grep -q "^$1:"
}

hydrate() {
    tmux send-keys -t $1 "source ~/.config/tmux/default-tmux-sessionizer" c-M
    # tmux select-window -t terminal 2>/dev/null || tmux new-window -n terminal
    # tmux select-window -t 1
}

if [[ $# -eq 1 ]]; then
    selected=$1
else
    # If someone wants to make this extensible, I'll accept
    # PR
    selected=$(find ~/Projects/Personal/ ~/Projects/Work/* ~/Documents/ ~/Projects -mindepth 1 -maxdepth 1 -type d | fzf --delimiter / --with-nth '{-2} -> {-1}' --keep-right --preview 'eza  --icons --oneline --color=always --tree --group-directories-first {} --level=2')
fi

if [[ -z $selected ]]; then
    exit 0
fi

selected_name=$(basename "$selected" | tr . _)
tmux_running=$(pgrep tmux)

if [[ -z $TMUX ]] && [[ -z $tmux_running ]]; then
    tmux new-session -ds $selected_name -c $selected
    hydrate $selected_name $selected
fi

if ! has_session $selected_name; then
    tmux new-session -ds $selected_name -c $selected
    hydrate $selected_name $selected
fi

switch_to $selected_name

