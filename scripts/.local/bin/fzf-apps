#!/bin/sh

export FZF_DEFAULT_OPTS=$FZF_DEFAULT_OPTS'
  --color=fg:#a9b1d6,fg+:#c0caf5,bg:#1a1b26,bg+:#283457
  --color=hl:#f7768e,hl+:#ff9e64,info:#565f89,marker:#9ece6a
  --color=prompt:#7dcfff,spinner:#89ddff,pointer:#9ece6a,header:#f7768e
  --color=gutter:#1a1b26,border:#565f89,label:#565f89,query:#a9b1d6
  --margin="0" --padding="0" --prompt="" --marker=" "
  --pointer=" " --separator="─" --scrollbar="│" --layout="reverse"
  --info="right"'

APP=$(lsdesktop | fzf --with-nth={1} --accept-nth=2 -d :)

if [ -n "$APP" ]; then
    desklaunch "$APP"
fi
